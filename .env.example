# 复制此文件为 .env 并填入真实值
# cp .env.example .env

# Notion Integration Token（在 https://www.notion.so/my-integrations 创建）
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 滴答清单"所有"数据库的 ID
# 从 Notion URL 中提取：https://notion.so/313c054f474a815e92dec8d659ab7ff7
# → 填写: 313c054f474a815e92dec8d659ab7ff7
NOTION_DATABASE_ID=313c054f474a815e92dec8d659ab7ff7

# 想法池数据库 ID（可选，用于将分类结果同步到想法池看板）
# 运行 create_pool_db.py 创建后，从输出中复制 ID
NOTION_POOL_DATABASE_ID=

# API Key
# - 使用 OpenAI 直连：填 OpenAI key（sk-...），不设置 OPENAI_BASE_URL
# - 使用 OpenRouter：填 OpenRouter key（sk-or-...），并设置下方 OPENAI_BASE_URL
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 使用 OpenRouter 时取消注释并填入：
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# 模型名称
# - OpenAI 直连示例：gpt-4o-mini
# - OpenRouter 示例：openai/gpt-4o-mini  anthropic/claude-3-haiku  google/gemini-flash-1.5
OPENAI_MODEL=gpt-4o-mini

# 置信度阈值：低于此值时标记为"待复核"而非"已分类"
CONFIDENCE_THRESHOLD=0.75
